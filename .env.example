PROJECT_ID=your-gcp-project-id
PROXY_API_KEY=your-secret-key-here

# For cloud deployments (Railway, Render, etc.) — base64-encoded service-account.json
# Generate with: base64 -w0 service-account.json
# GOOGLE_SA_JSON=<base64-encoded-json>

# Comma-separated IPs or CIDR ranges. Leave empty to allow all.
# ALLOWED_IPS=1.2.3.4,10.0.0.0/8

# Optional overrides
# PROXY_REGION=us-central1
# PROXY_PORT=8082
